# Ignore Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
venv/
env/
ENV/
.venv/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data files (too large for git)
data/raw/*.csv
data/processed/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep

# Model files (too large for git)
models/*.pkl
models/*.h5
models/*.joblib
models/*.sav
!models/.gitkeep

# Results and outputs
results/figures/*.png
results/figures/*.jpg
results/figures/*.pdf
results/tables/*.csv
results/predictions/*.csv
!results/figures/.gitkeep
!results/tables/.gitkeep
!results/predictions/.gitkeep

# Logs
*.log
logs/
airpure.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Environments
.env
.env.local

# Streamlit
.streamlit/

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Research paper drafts (keep only final)
research_paper/*.docx
research_paper/*.pdf
!research_paper/paper_outline.md

# Large datasets
*.zip
*.tar.gz
*.rar
